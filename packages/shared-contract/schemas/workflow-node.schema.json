{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.local/schemas/workflow-node.schema.json",
  "title": "WorkflowNode",
  "type": "object",
  "description": "工作流节点协议，用于约束固定节点类型、变量引用和核心配置。",
  "properties": {
    "nodeId": {
      "type": "string"
    },
    "nodeType": {
      "type": "string",
      "enum": ["trigger", "user_input", "agent", "parallel_group", "merge", "condition", "human_review", "delivery"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "inputVariables": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "outputVariables": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "config": {
      "type": "object"
    },
    "retryPolicy": {
      "type": "object"
    },
    "timeoutSeconds": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": ["nodeId", "nodeType", "name", "inputVariables", "outputVariables"],
  "additionalProperties": false,
  "allOf": [
    {
      "$comment": "智能体集群节点：执行方式仅支持并行（parallel，默认）与顺序（sequential），枚举保留扩展空间。",
      "if": {
        "properties": {
          "nodeType": { "const": "parallel_group" }
        }
      },
      "then": {
        "properties": {
          "config": {
            "type": "object",
            "properties": {
              "executionMode": {
                "type": "string",
                "enum": ["parallel", "sequential"],
                "default": "parallel"
              }
            }
          }
        }
      }
    }
  ]
}
