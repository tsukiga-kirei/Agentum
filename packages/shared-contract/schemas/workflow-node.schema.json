{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.local/schemas/workflow-node.schema.json",
  "title": "WorkflowNode",
  "type": "object",
  "description": "工作流节点协议，用于约束固定节点类型、变量引用和核心配置。",
  "properties": {
    "nodeId": {
      "type": "string"
    },
    "nodeType": {
      "type": "string",
      "enum": ["trigger", "user_input", "agent", "parallel_group", "merge", "condition", "human_review", "delivery"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "inputVariables": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "outputVariables": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "config": {
      "type": "object"
    },
    "retryPolicy": {
      "type": "object"
    },
    "timeoutSeconds": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": ["nodeId", "nodeType", "name", "inputVariables", "outputVariables"],
  "additionalProperties": false,
  "allOf": [
    {
      "$comment": "智能体集群节点：执行方式支持协同处理（collaborative）、接力处理（relay）与意图分派（intent）。意图分派通过 intentRoutes 绑定意图与目标子智能体，运行态只执行命中的子智能体。clusterOutputVariable 声明最终输出，mergeRule 只组合子智能体输出。历史 parallel/sequential 由数据库迁移清洗，不再作为契约值。",
      "if": {
        "properties": {
          "nodeType": { "const": "parallel_group" }
        }
      },
      "then": {
        "properties": {
          "config": {
            "type": "object",
            "properties": {
              "executionMode": {
                "type": "string",
                "enum": ["collaborative", "relay", "intent"],
                "default": "collaborative"
              },
              "clusterOutputVariable": {
                "type": "string",
                "default": "cluster_result"
              },
              "mergeRule": {
                "type": "string"
              },
              "intentSelectionMode": {
                "type": "string",
                "enum": ["single", "multiple"],
                "default": "multiple"
              },
              "intentInputTemplate": {
                "type": "string"
              },
              "intentFallbackMode": {
                "type": "string",
                "enum": ["fail", "agent", "fixed_reply"],
                "default": "fail"
              },
              "fallbackAgentId": {
                "type": "string"
              },
              "fallbackReply": {
                "type": "string"
              },
              "intentRoutes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["intentCode", "intentName", "intentDescription", "agentId"],
                  "properties": {
                    "id": { "type": "string" },
                    "intentCode": { "type": "string" },
                    "intentName": { "type": "string" },
                    "intentDescription": { "type": "string" },
                    "agentId": { "type": "string" }
                  },
                  "additionalProperties": true
                },
                "default": []
              }
            }
          }
        }
      }
    }
  ]
}
