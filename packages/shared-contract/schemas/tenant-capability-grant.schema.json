{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.local/schemas/tenant-capability-grant.schema.json",
  "title": "TenantCapabilityConfig",
  "type": "object",
  "description": "单租户能力配置协议，描述系统管理员在租户抽屉中把 Skill、MCP、提示词模板或交付能力启用给租户；模型分配使用独立协议。",
  "properties": {
    "tenantId": {
      "type": "string"
    },
    "capabilityId": {
      "type": "string"
    },
    "capabilityType": {
      "type": "string",
      "enum": ["skill", "mcp", "prompt_template", "delivery"]
    },
    "status": {
      "type": "string",
      "enum": ["enabled", "disabled"]
    },
    "quota": {
      "type": "object"
    }
  },
  "required": ["tenantId", "capabilityId", "capabilityType", "status"],
  "additionalProperties": false
}
