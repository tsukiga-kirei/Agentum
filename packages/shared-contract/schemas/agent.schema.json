{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentum.local/schemas/agent.schema.json",
  "title": "AgentTemplate",
  "type": "object",
  "description": "智能体模板协议，引用 Skills、MCP、提示词模板、模型配置和输出模式。",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mcpServices": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "promptTemplates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "modelConfig": {
      "type": "object"
    },
    "interactionMode": {
      "type": "string",
      "enum": ["once", "ask_then_confirm", "pause_then_continue"]
    },
    "outputSchema": {
      "type": "object"
    }
  },
  "required": ["id", "name", "version", "skills", "mcpServices", "promptTemplates", "modelConfig", "interactionMode"],
  "additionalProperties": false
}
