# Application
APP_ENV=local
SPRING_PROFILES_ACTIVE=local
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8080

# Security
# 以下值只是公开的本地开发默认值，不能用于生产。复制为 .env 后可替换；一旦产生字段密文，主密钥必须保持稳定。
AGENTUM_AUTH_TOKEN_SECRET=agentum-local-development-secret-change-before-production
AGENTUM_AUTH_SSO_STATE_SECRET=agentum-local-sso-state-secret-change-before-production
AGENTUM_FIELD_ENCRYPTION_MASTER_KEY=agentum-local-field-encryption-secret-change-before-production

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentum
POSTGRES_USER=agentum
POSTGRES_PASSWORD=agentum_dev_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=agentum
RABBITMQ_PASSWORD=agentum_dev_password

# Object Storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_ACCESS_KEY=agentum
MINIO_SECRET_KEY=agentum_dev_password
MINIO_BUCKET=agentum
MINIO_OBJECT_PREFIX=deliveries/documents
MINIO_AUTO_CREATE_BUCKET=true

# Mail
MAIL_HOST=localhost
MAIL_PORT=1025

# AI Provider
AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Agent Runtime
# 新流程节点的设计态建议值；实际运行值会保存到各智能体节点。
AGENTUM_AGENT_SUGGESTED_ITERATIONS_PER_TURN=4
# 平台允许单个智能体在一次初始执行或一次追问中的最大推理次数。
AGENTUM_AGENT_MAX_ITERATIONS_PER_TURN=20
