# Agentum Docker 部署环境样例
# 使用方式：复制为 .env 后修改真实值，再执行 docker compose up -d。
# 正式环境禁止沿用本文件中的 change-me 示例密码和密钥。

# 前后端镜像 tag。服务器已 docker load agentum-api:latest / agentum-web:latest 时保持 latest 即可；
# 若后续按版本发布，可改为 20260629、v1.0.0 等同一个 tag。
AGENTUM_IMAGE_TAG=latest

# Web 容器映射到宿主机的 HTTP 端口。正式环境常用 80；如果宿主机前面还有 Nginx/Caddy，可改为 127.0.0.1 反代侧端口映射方案。
WEB_HTTP_PORT=80

# Spring 运行 profile。部署测试和正式环境都应使用 prod，避免 local profile 加载 devdata 演示数据。
SPRING_PROFILES_ACTIVE=prod

# Docker network 名称。多套环境部署到同一台服务器时必须使用不同名称，例如 agentum-test / agentum-prod。
AGENTUM_DOCKER_NETWORK=agentum-prod

# 平台业务时区（IANA ID）。影响 API 定时任务、运行变量、日志行前缀时间与容器系统时区。
AGENTUM_TIMEZONE=Asia/Shanghai

# 后端对外基础地址，用于生成企业 SSO / OIDC 回调地址。
# 测试环境可填 http://测试服务器IP 或测试域名；正式环境应填 https://正式域名。
AGENTUM_AUTH_SSO_API_BASE_URL=http://localhost

# 前端对外基础地址，用于 SSO 登录完成后向前端窗口 postMessage 或回跳。
# 通常与 AGENTUM_AUTH_SSO_API_BASE_URL 使用同一个域名。
AGENTUM_AUTH_SSO_WEB_BASE_URL=http://localhost

# 后端 CORS 允许的前端来源。生产单域名通常与 AGENTUM_AUTH_SSO_WEB_BASE_URL 一致；
# 如需同时允许测试域名和正式域名，可用英文逗号分隔，例如 https://app.example.com,https://test.example.com。
AGENTUM_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost

# Access Token 签名密钥，用于签发和校验登录 JWT。
# 必须是正式环境独立强随机值，泄漏后需要强制所有用户重新登录。
AGENTUM_AUTH_TOKEN_SECRET=change-me-token-secret-at-least-32-random-chars

# SSO state 签名密钥，用于保护 OIDC 登录跳转过程中的 state/nonce，防止伪造登录回调。
# 必须与 AGENTUM_AUTH_TOKEN_SECRET 不同；泄漏会影响 SSO 登录链路安全。
AGENTUM_AUTH_SSO_STATE_SECRET=change-me-sso-state-secret-at-least-32-random-chars

# Basic 企业单点登录换取浏览器一次性地址的有效期（秒）。该地址仅可消费一次，不作为长期登录凭据。
AGENTUM_AUTH_BASIC_HANDOFF_TTL_SECONDS=60

# 字段加密主密钥，用于派生数据密钥，加密模型 API Key、OIDC Client Secret、外部交付凭证等敏感字段。
# 一旦生产库中已有密文，不能直接更换；更换前必须先实现旧密钥解密、新密钥重加密的轮换流程。
AGENTUM_FIELD_ENCRYPTION_MASTER_KEY=change-me-field-encryption-master-key-32-random-chars

# Access Token 有效期，单位分钟。建议保持较短，配合 Refresh Token 自动续签。
AGENTUM_AUTH_ACCESS_TOKEN_TTL_MINUTES=15

# Refresh Token 有效期，单位天。Refresh Token 通过 HttpOnly Cookie 保存，并在服务端可吊销。
AGENTUM_AUTH_REFRESH_TOKEN_TTL_DAYS=30

# Refresh Token Cookie 是否启用 Secure。
# 正式 HTTPS 环境必须为 true；仅 HTTP 测试环境可临时设为 false，否则浏览器不会回传 Cookie。
AGENTUM_AUTH_REFRESH_COOKIE_SECURE=true

# PostgreSQL 数据库名。首次启动时由 postgres 容器初始化创建。
POSTGRES_DB=agentum

# PostgreSQL 用户名。建议正式环境保持专用低权限账号，不使用 postgres 超级用户。
POSTGRES_USER=agentum

# PostgreSQL 密码。正式环境必须使用强随机值，并纳入服务器 Secret 管理或运维密码库。
POSTGRES_PASSWORD=change-me-postgres-password

# RabbitMQ 默认用户。API 运行态通过该账号投递和消费节点执行命令。
RABBITMQ_USER=agentum

# RabbitMQ 默认用户密码。正式环境必须使用强随机值。
RABBITMQ_PASSWORD=change-me-rabbitmq-password

# MinIO root/access key。当前 compose 使用内置 MinIO 存储 Word 等交付文件。
MINIO_ACCESS_KEY=agentum

# MinIO secret key。正式环境必须使用强随机值；泄漏后交付文件对象存储存在被读取或篡改风险。
MINIO_SECRET_KEY=change-me-minio-secret

# MinIO bucket 名称。API 会把文档交付文件写入该 bucket。
MINIO_BUCKET=agentum

# MinIO 对象前缀，用于把 Agentum 交付文档归入固定目录。
MINIO_OBJECT_PREFIX=deliveries/documents

# 是否由 API 自动创建 bucket。单机 Docker 首次部署可为 true；若使用外部 S3 且 bucket 已由运维创建，可设为 false。
MINIO_AUTO_CREATE_BUCKET=true

# 新建智能体节点时的设计态建议推理轮次；运行时实际值会保存到工作流节点快照。
AGENTUM_AGENT_SUGGESTED_ITERATIONS_PER_TURN=4

# 平台允许单个智能体在一次初始执行或一次追问中的最大推理轮次，用于限制成本和长时间循环。
AGENTUM_AGENT_MAX_ITERATIONS_PER_TURN=20

# 单个运行态节点最大执行时长，单位秒。超过后由运行态回收任务，避免节点无限占用 Worker。
AGENTUM_RUNTIME_NODE_TIMEOUT_SECONDS=1800

# API 内置运行态 Worker 并发数。机器资源较小时可调低，模型/MCP 调用较多且资源充足时可调高。
AGENTUM_RUNTIME_WORKER_CONCURRENCY=4

# 智能体集群节点并行子任务上限，用于控制模型调用、MCP 调用和队列压力。
AGENTUM_RUNTIME_CLUSTER_PARALLELISM=4

# 运行作业失联判定阈值，单位秒。超过该时间未续租的执行会被回收为可恢复/失败状态。
AGENTUM_RUNTIME_STALE_THRESHOLD_SECONDS=120
